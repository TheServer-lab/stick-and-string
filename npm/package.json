{
  "name": "stick-and-string",
  "version": "1.1.0",
  "description": "SAS 1.1 (Stick And String) — human-readable data serialization format. Parser, validator, and bidirectional JSON converter.",
  "main": "index.js",
  "module": "index.mjs",
  "browser": "index.mjs",
  "bin": {
    "sas": "./cli.js"
  },
  "exports": {
    ".": {
      "import": "./index.mjs",
      "require": "./index.js",
      "browser": "./index.mjs"
    },
    "./parser": {
      "import": "./sas-parser.mjs",
      "require": "./sas-parser.js"
    },
    "./sas-to-json": {
      "import": "./sas-to-json.mjs",
      "require": "./sas-to-json.js"
    },
    "./json-to-sas": {
      "import": "./json-to-sas.mjs",
      "require": "./json-to-sas.js"
    }
  },
  "scripts": {
    "test": "node test.js",
    "prepublishOnly": "npm test"
  },
  "files": [
    "index.js",
    "index.mjs",
    "sas-parser.js",
    "sas-parser.mjs",
    "sas-to-json.js",
    "sas-to-json.mjs",
    "json-to-sas.js",
    "json-to-sas.mjs",
    "cli.js",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "sas",
    "stick-and-string",
    "parser",
    "serialization",
    "json",
    "config",
    "data-format",
    "human-readable"
  ],
